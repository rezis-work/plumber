# Public env vars (exposed to the browser). Copy to `.env` and adjust.

# Public HTTPS origin of this site (no trailing slash), e.g. https://www.example.com
# Used for canonical, hreflang, and og:url in production when the app sits behind a reverse proxy.
# Leave unset to use the request URL origin (typical for local dev).
# PUBLIC_SITE_URL=

# API origin for cross-origin calls from the browser (e.g. http://localhost:3001).
# Leave empty to use same-origin relative URLs such as `/auth/...` (Vite dev proxy or reverse proxy).
# PUBLIC_API_URL=
