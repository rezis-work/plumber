# Neon PostgreSQL connection string.
# Use the pooled (-pooler) URL for the running API in production/serverless.
# If `sqlx migrate run` fails through the pooler, use the direct (non-pooler) URL for migrations only.
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Apply migrations (from apps/api): sqlx migrate run
# Run repository integration test: cargo test -- --ignored

# Password policy (optional; defaults shown)
# AUTH_PASSWORD_MIN_LENGTH=8
# AUTH_PASSWORD_MAX_LENGTH=256

# Argon2id tuning for NEW hashes only. Verification uses params embedded in each stored PHC string.
# AUTH_ARGON2_M_COST=19456
# AUTH_ARGON2_T_COST=3
# AUTH_ARGON2_P_COST=1

# Client registration: HMAC-SHA256 key for email verification token (required in production).
# Dev default is insecure; set a long random secret for real deployments.
# AUTH_EMAIL_VERIFICATION_SECRET=

# Hours until client verification token expires (default 48).
# AUTH_EMAIL_VERIFICATION_TTL_HOURS=48

# Plumber registration (Option B): new plumbers get is_email_verified=true with no outbound email;
# switching to Option A later is additive (same verification fields as clients).

# Manual checks (API default port 3001): POST /auth/register/client with {"email","password"};
# POST /auth/register/plumber with {"email","password","full_name","phone","years_of_experience"}.
# Expect 201; duplicate email → 409; weak/invalid input → 400. Responses must not include password_hash.

# JWT (HS256). Use distinct long random secrets in production; dev defaults are insecure.
# AUTH_JWT_ACCESS_SECRET=
# AUTH_JWT_REFRESH_SECRET=
# AUTH_JWT_ACCESS_TTL_MINUTES=15
# AUTH_JWT_REFRESH_TTL_DAYS=7
# Optional registered claims (if set, tokens include and validate iss/aud):
# AUTH_JWT_ISSUER=
# AUTH_JWT_AUDIENCE=
# Refresh sessions (refresh_tokens table): store hex(HMAC-SHA256(AUTH_JWT_REFRESH_SECRET, raw_refresh_jwt)),
# never the plaintext JWT. Same secret as refresh signing; optional future split: AUTH_REFRESH_TOKEN_HMAC_SECRET.

# POST /auth/login: JSON body {"email","password"} → 200 + access_token JSON + Set-Cookie (httpOnly refresh JWT).
# Policy defaults: unverified email may still log in (use /auth/me when added); disabled user → 403 account_inactive.
# Wrong password and unknown email share the same 401 JSON (invalid_credentials).
# AUTH_REFRESH_COOKIE_NAME=refresh_token
# AUTH_REFRESH_COOKIE_PATH=/auth
# AUTH_REFRESH_COOKIE_SAMESITE=lax
# AUTH_REFRESH_COOKIE_SECURE=false
# Set AUTH_REFRESH_COOKIE_SECURE=true (and HTTPS) in production. SameSite=None requires Secure.
# Also sets Secure when APP_ENV=production.
