# Public API origin (HTTPS). Devices and simulators often cannot use localhost — use ngrok
# (or similar) to expose your API, then paste the HTTPS origin here.
# No trailing slash.
EXPO_PUBLIC_API_URL=https://your-subdomain.ngrok-free.app

# Optional (Android dev): if EXPO_PUBLIC_API_URL is http://..., app.config.ts enables cleartext automatically.
# To force cleartext when the URL is https (not recommended), set:
# EXPO_PUBLIC_ANDROID_CLEARTEXT=true
